{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020"],
    "strict": false,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./src",
    "noUncheckedIndexedAccess": false,
    "paths": {
      "@config/*": ["config/*"],
      "@lib/*": ["lib/*"],
      "@scenarios/*": ["scenarios/*"],
      "@data/*": ["data/*"],
      "@tests/*": ["tests/*"],
      "@types/*": ["types/*"]
    },
    "typeRoots": ["./node_modules/@types", "./src/types"],
    "types": ["k6"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "reports"]
}
