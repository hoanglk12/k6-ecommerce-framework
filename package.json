{
  "name": "k6-ecommerce-framework",
  "version": "1.0.0",
  "description": "Production-ready k6 TypeScript framework for load testing Australian eCommerce platforms",
  "main": "dist/index.js",
  "scripts": {
    "clean": "rimraf dist",
    "build": "webpack --config webpack.config.js",
    "build:watch": "webpack --config webpack.config.js --watch",
    "test:load": "k6 run --vus 200 --duration 10m dist/tests/load.test.js",
    "test:load:platypus-au": "k6 run --vus 200 --duration 10m -e SITE=platypus-au -e ENVIRONMENT=staging dist/tests/load.test.js",
    "test:load:platypus-au:prod": "k6 run --vus 200 --duration 10m -e SITE=platypus-au -e ENVIRONMENT=production dist/tests/load.test.js",
    "test:load:platypus-nz": "k6 run --vus 200 --duration 10m -e SITE=platypus-nz -e ENVIRONMENT=staging dist/tests/load.test.js",
    "test:load:platypus-nz:prod": "k6 run --vus 200 --duration 10m -e SITE=platypus-nz -e ENVIRONMENT=production dist/tests/load.test.js",
    "test:load:skechers-au": "k6 run --vus 200 --duration 10m -e SITE=skechers-au -e ENVIRONMENT=staging dist/tests/load.test.js",
    "test:load:skechers-au:prod": "k6 run --vus 200 --duration 10m -e SITE=skechers-au -e ENVIRONMENT=production dist/tests/load.test.js",
    "test:load:skechers-nz": "k6 run --vus 200 --duration 10m -e SITE=skechers-nz -e ENVIRONMENT=staging dist/tests/load.test.js",
    "test:load:skechers-nz:prod": "k6 run --vus 200 --duration 10m -e SITE=skechers-nz -e ENVIRONMENT=production dist/tests/load.test.js",
    "test:load:drmartens-au": "k6 run --vus 200 --duration 10m -e SITE=drmartens-au -e ENVIRONMENT=staging dist/tests/load.test.js",
    "test:load:drmartens-au:prod": "k6 run --vus 200 --duration 10m -e SITE=drmartens-au -e ENVIRONMENT=production dist/tests/load.test.js",
    "test:load:drmartens-nz": "k6 run --vus 200 --duration 10m -e SITE=drmartens-nz -e ENVIRONMENT=staging dist/tests/load.test.js",
    "test:load:drmartens-nz:prod": "k6 run --vus 200 --duration 10m -e SITE=drmartens-nz -e ENVIRONMENT=production dist/tests/load.test.js",
    "test:load:vans-au": "k6 run --vus 200 --duration 10m -e SITE=vans-au -e ENVIRONMENT=staging dist/tests/load.test.js",
    "test:load:vans-au:prod": "k6 run --vus 200 --duration 10m -e SITE=vans-au -e ENVIRONMENT=production dist/tests/load.test.js",
    "test:load:vans-nz": "k6 run --vus 200 --duration 10m -e SITE=vans-nz -e ENVIRONMENT=staging dist/tests/load.test.js",
    "test:load:vans-nz:prod": "k6 run --vus 200 --duration 10m -e SITE=vans-nz -e ENVIRONMENT=production dist/tests/load.test.js",
    "test:stress": "k6 run dist/tests/stress.test.js",
    "test:spike": "k6 run dist/tests/spike.test.js",
    "test:soak": "k6 run dist/tests/soak.test.js",
    "test:cloud": "k6 cloud dist/tests/load.test.js",
    "test:cloud:platypus-au": "k6 cloud -e SITE=platypus-au dist/tests/load.test.js",
    "test:cloud:skechers-au": "k6 cloud -e SITE=skechers-au dist/tests/load.test.js",
    "dashboard": "k6 run --out web-dashboard dist/tests/load.test.js",
    "dashboard:platypus-au": "k6 run --out web-dashboard --vus 50 --duration 5m -e SITE=platypus-au -e ENVIRONMENT=staging dist/tests/load.test.js",
    "dashboard:skechers-au": "k6 run --out web-dashboard --vus 50 --duration 5m -e SITE=skechers-au -e ENVIRONMENT=staging dist/tests/load.test.js",
    "dry-run": "k6 run --vus 1 --iterations 1 -e DRY_RUN=true dist/tests/load.test.js",
    "validate": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "prepare": "npm run build"
  },
  "keywords": [
    "k6",
    "load-testing",
    "performance-testing",
    "typescript",
    "graphql",
    "ecommerce",
    "magento",
    "adobe-commerce"
  ],
  "author": "Performance Engineering Team",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-typescript": "^7.24.0",
    "@types/k6": "^0.49.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "babel-loader": "^9.1.3",
    "clean-webpack-plugin": "^4.0.0",
    "copy-webpack-plugin": "^12.0.2",
    "eslint": "^8.57.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.4.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4",
    "webpack-glob-entries": "^1.0.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
