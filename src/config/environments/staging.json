    },
    "platypus-nz": {
      "baseUrl": "https://stag-platypus-nz.accentgra.com",
      "graphqlEndpoint": "https://stag-platypus-nz.accentgra.com/graphql",
      "storeCode": "default"
    },
    "skechers-au": {
      "baseUrl": "https://stag-skechers-au.accentgra.com",
      "graphqlEndpoint": "https://stag-skechers-au.accentgra.com/graphql",
      "storeCode": "default"
    },
    "skechers-nz": {
      "baseUrl": "https://stag-skechers-nz.accentgra.com",
      "graphqlEndpoint": "https://stag-skechers-nz.accentgra.com/graphql",
      "storeCode": "default"
    },
    "drmartens-au": {
      "baseUrl": "https://stag-drmartens-au.accentgra.com",
      "graphqlEndpoint": "https://stag-drmartens-au.accentgra.com/graphql",
      "storeCode": "default"
    },
    "drmartens-nz": {
      "baseUrl": "https://stag-drmartens-nz.accentgra.com",
