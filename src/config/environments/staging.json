      "baseUrl": "https://stag-vans-au.accentgra.com",
      "graphqlEndpoint": "https://stag-vans-au.accentgra.com/graphql",
      "storeCode": "default"
    },
    "vans-nz": {
      "baseUrl": "https://stag-vans-nz.accentgra.com",
      "graphqlEndpoint": "https://stag-vans-nz.accentgra.com/graphql",
      "storeCode": "default"
    }
  },
  "thresholds": {
    "http_req_duration_p95": 1000,
    "http_req_duration_p99": 3000,
    "http_req_failed_rate": 0.05,
    "http_req_waiting_p95": 300
